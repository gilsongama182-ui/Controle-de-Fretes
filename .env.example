# VITE_SUPABASE_URL: URL do seu projeto Supabase (Project Settings > API > Project URL)
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# VITE_SUPABASE_ANON_KEY: chave pública anônima do projeto (Project Settings > API > anon public)
# É segura para expor no frontend — o acesso real é controlado pelas políticas de RLS no banco.
VITE_SUPABASE_ANON_KEY="eyJ..."

# ---------------------------------------------------------------------------
# Variáveis abaixo são usadas SÓ pelas funções serverless em /api (nunca têm
# prefixo VITE_, então nunca são incluídas no bundle enviado ao navegador).
# ---------------------------------------------------------------------------

# SUPABASE_SERVICE_ROLE_KEY: chave secreta (Project Settings > API > service_role).
# Usada só pela tabela melhor_envio_tokens, que não tem nenhuma policy de RLS.
# NUNCA usar prefixo VITE_ nesta variável.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Credenciais do aplicativo criado no painel de desenvolvedor da Melhor Envio.
MELHOR_ENVIO_CLIENT_ID="..."
MELHOR_ENVIO_CLIENT_SECRET="..."
# Precisa bater exatamente com a "Callback URL" cadastrada no aplicativo.
MELHOR_ENVIO_REDIRECT_URI="https://seu-dominio.vercel.app/api/melhor-envio/callback"
# "sandbox" (padrão) ou "production"
MELHOR_ENVIO_ENV="sandbox"

# Segredo comparado contra o header "Authorization: Bearer <CRON_SECRET>" que
# o próprio Vercel injeta automaticamente nas chamadas dos Cron Jobs
# (vercel.json -> crons) quando essa env var está configurada no projeto —
# é o que impede qualquer chamada externa direta às rotas de cron-sync.
# Usado tanto pelo cron da Melhor Envio quanto pelo da Loggi.
CRON_SECRET="..."

# Login real (usuário/senha) da conta da Loggi — não existe API oficial pra
# essa conta, então o cron da Loggi loga no site via navegador headless pra
# ler o painel de envios. NUNCA usar prefixo VITE_ aqui.
LOGGI_LOGIN_EMAIL="..."
LOGGI_LOGIN_PASSWORD="..."
# Opcionais: só preencher se for preciso corrigir URLs/seletores/textos sem
# precisar de um novo deploy (ver comentários em api/loggi/_shared.ts).
# LOGGI_LOGIN_URL="https://app.loggi.com/entrar"
# LOGGI_SHIPMENTS_URL="https://app.loggi.com/envios"
# LOGGI_CONTINUE_BUTTON_TEXT="Continuar"
# LOGGI_ROW_SELECTOR="[data-testid=\"shipment-row\"]"
# LOGGI_TRACKING_SELECTOR="[data-testid=\"tracking-code\"]"
# LOGGI_STATUS_SELECTOR="[data-testid=\"shipment-status\"]"
